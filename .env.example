# ── Database ──────────────────────────────────────────────────────
# Supabase PostgreSQL connection string (used by Drizzle ORM)
SUPABASE_DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# ── Auth ──────────────────────────────────────────────────────────
# Full URL of the app (used by better-auth for OAuth callbacks)
BETTER_AUTH_URL=https://bloq5.com

# Session secret — generate with: openssl rand -base64 32
SESSION_SECRET=change-me-with-a-strong-random-value

# ── OAuth providers ───────────────────────────────────────────────
# Google Cloud Console → APIs & Services → Credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ── Email (Resend) ────────────────────────────────────────────────
RESEND_API_KEY=re_your_resend_api_key

# ── Payments (Stripe — add when ready) ───────────────────────────
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# ── Runtime ───────────────────────────────────────────────────────
NODE_ENV=production
PORT=8080

# ── CORS (comma-separated list of allowed domains) ────────────────
# In production, DigitalOcean sets this automatically via app.yaml
REPLIT_DOMAINS=bloq5.com,www.bloq5.com
